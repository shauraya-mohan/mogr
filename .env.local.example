# Copy to .env.local and fill in. Never commit .env.local.

# Supabase — from your project dashboard (Project Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# OpenAI — server-only (vision read + image generation). Never exposed client-side.
OPENAI_API_KEY=sk-your-key
OPENAI_VISION_MODEL=gpt-5.1-chat-latest
OPENAI_IMAGE_MODEL=gpt-image-2
